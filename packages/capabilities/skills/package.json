{
  "name": "@crabbykit/skills",
  "version": "0.0.1",
  "homepage": "https://github.com/crabbykit/claw#readme",
  "bugs": {
    "url": "https://github.com/crabbykit/claw/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crabbykit/claw.git",
    "directory": "packages/capabilities/skills"
  },
  "license": "MIT",
  "author": "Tim O'Connell",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./service": "./src/service.ts",
    "./client": "./src/client.ts",
    "./schemas": "./src/schemas.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "bun ../../../scripts/build-package.ts",
    "prepublishOnly": "bun run build",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@crabbykit/agent-runtime": "workspace:^",
    "@crabbykit/agent-core": "workspace:^",
    "@crabbykit/agent-storage": "workspace:^",
    "@crabbykit/bundle-token": "workspace:^",
    "@crabbykit/skill-registry": "workspace:^",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@vitest/coverage-istanbul": "^3.2.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0",
    "@vitest/coverage-v8": "^3.2.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.js"
      },
      "./schemas": {
        "types": "./dist/schemas.d.ts",
        "import": "./dist/schemas.js"
      }
    }
  }
}
