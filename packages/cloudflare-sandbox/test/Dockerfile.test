# Test Dockerfile — no FUSE/tigrisfs, uses regular directory as workspace.
# Requires SYS_ADMIN for mount --bind (nm-guard).

FROM node:22-alpine

RUN apk add --no-cache coreutils gosu shadow curl

# Create unprivileged user
RUN useradd -m -s /bin/sh gia

# Create workspace and persist directories (no FUSE — just regular dirs)
RUN mkdir -p /mnt/r2 /opt/gia/persist /opt/gia/nm && \
    chown -R gia:gia /mnt/r2 /opt/gia

WORKDIR /app

# Copy nm-guard and server
COPY container/nm-guard.sh container/server.ts /app/
RUN chmod +x /app/nm-guard.sh

EXPOSE 8080

# Test entrypoint: start nm-guard as root, then drop to gia for server
CMD sh -c '/app/nm-guard.sh & exec gosu gia node --experimental-strip-types /app/server.ts'
