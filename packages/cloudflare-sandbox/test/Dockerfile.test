# Test Dockerfile — no FUSE/tigrisfs, uses regular directory as workspace.
# Requires SYS_ADMIN for mount --bind (nm-guard + nm-intercept).

FROM node:22-alpine

RUN apk add --no-cache coreutils gosu shadow curl gcc musl-dev linux-headers python3 make g++

# Create unprivileged user
RUN useradd -m -s /bin/sh sandbox

# Create workspace and persist directories (no FUSE — just regular dirs)
RUN mkdir -p /mnt/r2 /opt/sandbox/persist /opt/sandbox/nm && \
    chown -R sandbox:sandbox /mnt/r2 /opt/sandbox

WORKDIR /app

# Compile nm-mount-helper (setuid root binary) and nm-intercept (LD_PRELOAD library)
COPY container/nm-mount-helper.c container/nm-intercept.c /tmp/
RUN gcc -o /usr/local/bin/nm-mount-helper /tmp/nm-mount-helper.c && \
    chmod u+s /usr/local/bin/nm-mount-helper && \
    gcc -shared -fPIC -o /usr/local/lib/nm-intercept.so /tmp/nm-intercept.c -ldl && \
    rm /tmp/nm-mount-helper.c /tmp/nm-intercept.c

# Install node-pty (native module — must be compiled inside the container)
RUN cd /app && npm install node-pty && \
    apk del gcc musl-dev linux-headers python3 make g++

# Install @claw-for-cloudflare/vite-plugin globally
COPY container/claw-vite-plugin/ /opt/sandbox/claw-vite-plugin/
RUN npm install -g /opt/sandbox/claw-vite-plugin

# Copy nm-guard and server
COPY container/nm-guard.sh container/server.ts /app/
RUN chmod +x /app/nm-guard.sh

# Set up LD_PRELOAD for nm-intercept
ENV LD_PRELOAD=/usr/local/lib/nm-intercept.so \
    NM_INTERCEPT_MOUNT=/mnt/r2 \
    NM_INTERCEPT_BASE=/opt/sandbox/nm

EXPOSE 8080

# Test entrypoint: start nm-guard as root fallback, then drop to sandbox for server
# LD_PRELOAD is inherited by the node process for instant node_modules interception
CMD sh -c '/app/nm-guard.sh & exec gosu sandbox node --experimental-strip-types /app/server.ts'
