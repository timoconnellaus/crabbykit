{
  "name": "@crabbykit/agent-ui",
  "version": "0.0.1",
  "homepage": "https://github.com/crabbykit/claw#readme",
  "bugs": {
    "url": "https://github.com/crabbykit/claw/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crabbykit/claw.git",
    "directory": "packages/ui/agent-ui"
  },
  "license": "MIT",
  "author": "Tim O'Connell",
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "bun ../../../scripts/build-package.ts",
    "prepublishOnly": "bun run build",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-yaml": "^6.1.1",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.0",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-visually-hidden": "^1.1.0",
    "@tanstack/react-virtual": "^3.13.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.4.2"
  },
  "peerDependencies": {
    "@crabbykit/agent-runtime": "workspace:^",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0",
    "@vitest/coverage-istanbul": "^3.2.0",
    "@vitest/coverage-v8": "^3.2.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./styles.css": "./dist/styles.css"
    }
  }
}
