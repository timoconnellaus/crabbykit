{
  "name": "agent-runtime-test",
  "main": "src/test-helpers/test-agent-do.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "AGENT",
        "class_name": "TestAgentDO"
      },
      {
        "name": "TEST_BUNDLE_AGENT",
        "class_name": "TestBundleAgentDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TestAgentDO"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["TestBundleAgentDO"]
    }
  ]
}
