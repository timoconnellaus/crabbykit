{
  "name": "@crabbykit/agent-runtime",
  "version": "0.0.1",
  "homepage": "https://github.com/crabbykit/claw#readme",
  "bugs": {
    "url": "https://github.com/crabbykit/claw/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crabbykit/claw.git",
    "directory": "packages/runtime/agent-runtime"
  },
  "license": "MIT",
  "author": "Tim O'Connell",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./modes": "./src/modes/index.ts",
    "./test-utils": "./src/test-utils.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "bun ../../../scripts/build-package.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@crabbykit/a2a": "workspace:^",
    "@crabbykit/agent-core": "workspace:^",
    "@crabbykit/ai": "workspace:^",
    "@crabbykit/bundle-host": "workspace:^",
    "@crabbykit/bundle-sdk": "workspace:^",
    "@crabbykit/bundle-token": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@sinclair/typebox": "^0.34.0",
    "nanoid": "^5.1.5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@vitest/coverage-istanbul": "^3.2.0",
    "typescript": "^5.7.0",
    "@types/react": "^19.0.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./client": {
        "types": "./dist/client/index.d.ts",
        "import": "./dist/client/index.js"
      },
      "./modes": {
        "types": "./dist/modes/index.d.ts",
        "import": "./dist/modes/index.js"
      },
      "./test-utils": {
        "types": "./dist/test-utils.d.ts",
        "import": "./dist/test-utils.js"
      }
    }
  }
}
