{
  "name": "@crabbykit/bundle-host",
  "version": "0.0.1",
  "homepage": "https://github.com/crabbykit/claw#readme",
  "bugs": {
    "url": "https://github.com/crabbykit/claw/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crabbykit/claw.git",
    "directory": "packages/runtime/bundle-host"
  },
  "license": "MIT",
  "author": "Tim O'Connell",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "bun ../../../scripts/build-package.ts",
    "prepublishOnly": "bun run build",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@crabbykit/agent-runtime": "workspace:^",
    "@crabbykit/bundle-registry": "workspace:^",
    "@crabbykit/bundle-sdk": "workspace:^",
    "@crabbykit/bundle-token": "workspace:^",
    "@cloudflare/worker-bundler": "^0.1.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "esbuild-wasm": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0",
    "@vitest/coverage-istanbul": "^3.2.0",
    "@vitest/coverage-v8": "^3.2.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
