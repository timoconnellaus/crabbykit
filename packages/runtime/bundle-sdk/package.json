{
  "name": "@crabbykit/bundle-sdk",
  "version": "0.0.1",
  "homepage": "https://github.com/crabbykit/claw#readme",
  "bugs": {
    "url": "https://github.com/crabbykit/claw/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crabbykit/claw.git",
    "directory": "packages/runtime/bundle-sdk"
  },
  "license": "MIT",
  "author": "Tim O'Connell",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./runtime-source": {
      "types": "./dist/bundle-runtime-source.d.ts",
      "default": "./dist/bundle-runtime-source.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "postinstall": "bun build.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@crabbykit/agent-core": "workspace:^",
    "@crabbykit/agent-runtime": "workspace:^",
    "@crabbykit/ai": "workspace:^",
    "@crabbykit/bundle-token": "workspace:^",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./runtime-source": {
        "types": "./dist/bundle-runtime-source.d.ts",
        "default": "./dist/bundle-runtime-source.js"
      }
    }
  }
}
