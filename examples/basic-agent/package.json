  "bin": {
    "claw": "./cli/index.ts"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.1.0",
    "@claw-for-cloudflare/ai-proxy": "workspace:*",
    "@claw-for-cloudflare/agent-runtime": "workspace:*",
    "@claw-for-cloudflare/agent-storage": "workspace:*",
    "@claw-for-cloudflare/agent-ui": "workspace:*",
    "@claw-for-cloudflare/cloudflare-sandbox": "workspace:*",
    "@claw-for-cloudflare/agent-auth": "workspace:*",
    "@claw-for-cloudflare/agent-fleet": "workspace:*",
    "@claw-for-cloudflare/agent-peering": "workspace:*",
    "@claw-for-cloudflare/agent-registry": "workspace:*",
    "@claw-for-cloudflare/compaction-summary": "workspace:*",
    "@claw-for-cloudflare/credential-store": "workspace:*",
    "@claw-for-cloudflare/heartbeat": "workspace:*",
    "@claw-for-cloudflare/prompt-scheduler": "workspace:*",
    "@claw-for-cloudflare/r2-storage": "workspace:*",
    "@claw-for-cloudflare/sandbox": "workspace:*",
