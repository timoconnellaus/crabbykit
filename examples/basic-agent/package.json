    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  },
  "scripts": {
    "dev": "node ../../tools/docker-fuse-proxy.mjs & sleep 1 && DOCKER_HOST=unix:///tmp/docker-fuse-proxy.sock vite",
    "dev:no-sandbox": "vite",
    "build": "vite build",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit"
