{
  "name": "basic-agent",
  "main": "src/server.ts",
  // 2025-12-01 enables DurableObjectState.exports (ctx.exports), which is
  // required by @cloudflare/containers 0.2.x at container startup when
  // outboundByHost is used. Without this, SandboxContainer throws
  // "ctx.exports is undefined" on /health.
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    // R2 bucket name — must match the r2_buckets bucket_name below.
    // Used by SandboxContainer to configure FUSE mount inside the container.
    "R2_BUCKET_NAME": "basic-agent-storage",
    // Agent-ops shared secret (override in production via wrangler secret put)
    "AGENT_SECRET": "dev-secret-change-in-production",
    // Bundle brain override HMAC key (override in production via wrangler secret put)
    "AGENT_AUTH_KEY": "dev-bundle-auth-key-change-in-production"
  },
  // Secrets (set via `wrangler secret put`):
  // - OPENROUTER_API_KEY
  // - TAVILY_API_KEY
  // - AWS_ACCESS_KEY_ID     (R2 API token — for container FUSE mount)
  // - AWS_SECRET_ACCESS_KEY (R2 API token — for container FUSE mount)
  // - R2_ACCOUNT_ID         (Cloudflare account ID — for container FUSE mount)
  // - PUBLIC_URL            (optional — default webhook origin used by the
  //                          Telegram channel; e.g. https://xxx.trycloudflare.com.
  //                          Telegram bot tokens themselves are NOT set as env
  //                          vars; they're added from the Channels UI page.)
  "durable_objects": {
    "bindings": [
      {
        "name": "AGENT",
        "class_name": "BasicAgent"
      },
      {
        "name": "SANDBOX_CONTAINER",
        "class_name": "SandboxContainer"
      },
      {
        "name": "BACKEND_STORAGE",
        "class_name": "BackendStorage"
      }
    ]
  },
  "containers": [
    {
      "class_name": "SandboxContainer",
      "image": "../../packages/infra/cloudflare-sandbox/container/Dockerfile",
      "image_build_context": "../../",
      "instance_type": "basic"
    }
  ],
  "services": [
    {
      "binding": "DB_SERVICE",
      "service": "basic-agent",
      "entrypoint": "DbService"
    },
    {
      "binding": "AI_SERVICE",
      "service": "basic-agent",
      "entrypoint": "AiService"
    },
    {
      "binding": "SPINE_SERVICE",
      "service": "basic-agent",
      "entrypoint": "SpineService"
    },
    {
      "binding": "LLM_SERVICE",
      "service": "basic-agent",
      "entrypoint": "LlmService"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "r2_buckets": [
    {
      "binding": "STORAGE_BUCKET",
      "bucket_name": "basic-agent-storage",
      "remote": true
    }
  ],
  "vectorize": [
    {
      "binding": "MEMORY_INDEX",
      "index_name": "basic-agent-memory",
      "remote": true
    }
  ],
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "d1_databases": [
    {
      "binding": "AGENT_DB",
      "database_name": "agent-registry",
      "database_id": "local"
    },
    {
      "binding": "SKILL_DB",
      "database_name": "skill-registry",
      "database_id": "local"
    },
    {
      "binding": "BUNDLE_DB",
      "database_name": "bundle-registry",
      "database_id": "local"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "BUNDLE_KV",
      "id": "local"
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["BasicAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["SandboxContainer"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["BackendStorage"]
    }
  ]
}
