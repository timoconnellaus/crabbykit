    "@claw-for-cloudflare/compaction-summary": "workspace:*",
    "@claw-for-cloudflare/prompt-scheduler": "workspace:*",
    "@claw-for-cloudflare/tavily-web-search": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
